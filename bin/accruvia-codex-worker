#!/usr/bin/env bash
set -euo pipefail

run_dir="${ACCRUVIA_RUN_DIR:?}"
workspace="${ACCRUVIA_PROJECT_WORKSPACE:?}"
task_id="${ACCRUVIA_TASK_ID:?}"
run_id="${ACCRUVIA_RUN_ID:?}"
objective="${ACCRUVIA_TASK_OBJECTIVE:?}"
summary="${ACCRUVIA_RUN_SUMMARY:-}"
strategy="${ACCRUVIA_TASK_STRATEGY:-default}"

plan_path="${run_dir}/plan.txt"
report_path="${run_dir}/report.json"
stdout_path="${run_dir}/codex_worker.stdout.txt"
stderr_path="${run_dir}/codex_worker.stderr.txt"
compile_output_path="${run_dir}/compile_output.txt"
test_output_path="${run_dir}/test_output.txt"
prompt_path="${run_dir}/codex_worker_prompt.txt"

cat >"${plan_path}" <<EOF
Task ${task_id}
Run ${run_id}
Strategy: ${strategy}
Objective: ${objective}
Plan summary: ${summary}
EOF

cat >"${prompt_path}" <<EOF
You are operating inside an isolated git worktree for the repository under test.

Task ID: ${task_id}
Run ID: ${run_id}
Objective: ${objective}
Plan summary: ${summary}

Requirements:
- Make the smallest reasonable code changes to accomplish the objective.
- Work only inside the current repository checkout.
- Prefer touching tests when behavior or UX changes.
- Do not ask for interactive approval.
- Before finishing, run a focused validation command if practical.
- Print a short plain-English completion summary to stdout.
EOF

set +e
(cd "${workspace}" && codex exec <"${prompt_path}" >"${stdout_path}" 2>"${stderr_path}")
codex_rc=$?
set -e

python_files="$(cd "${workspace}" && git diff --name-only -- '*.py' || true)"
if [ -n "${python_files}" ]; then
  set +e
  (cd "${workspace}" && python3 -m py_compile ${python_files}) >"${compile_output_path}" 2>&1
  compile_rc=$?
  set -e
else
  printf 'No Python files changed.\n' >"${compile_output_path}"
  compile_rc=0
fi

set +e
(cd "${workspace}" && python3 -m unittest tests.test_cli tests.test_phase1 tests.test_supervisor tests.test_observer) >"${test_output_path}" 2>&1
test_rc=$?
set -e

export ACCRUVIA_CODEX_RC="${codex_rc}"
export ACCRUVIA_COMPILE_RC="${compile_rc}"
export ACCRUVIA_TEST_RC="${test_rc}"

python3 - <<'PY'
import json
import os
import subprocess
from pathlib import Path

workspace = Path(os.environ["ACCRUVIA_PROJECT_WORKSPACE"])
run_dir = Path(os.environ["ACCRUVIA_RUN_DIR"])
stdout_path = run_dir / "codex_worker.stdout.txt"
report_path = run_dir / "report.json"
compile_output_path = run_dir / "compile_output.txt"
test_output_path = run_dir / "test_output.txt"
compile_rc = int(os.environ["ACCRUVIA_COMPILE_RC"])
test_rc = int(os.environ["ACCRUVIA_TEST_RC"])
codex_rc = int(os.environ["ACCRUVIA_CODEX_RC"])

changed_files = [
    line.strip()
    for line in subprocess.run(
        ["git", "-C", str(workspace), "diff", "--name-only"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.splitlines()
    if line.strip()
]
untracked_files = [
    line.strip()
    for line in subprocess.run(
        ["git", "-C", str(workspace), "ls-files", "--others", "--exclude-standard"],
        check=True,
        capture_output=True,
        text=True,
    ).stdout.splitlines()
    if line.strip()
]
all_changed = sorted(dict.fromkeys(changed_files + untracked_files))
test_files = [
    path for path in all_changed
    if "/test" in path or path.startswith("tests/") or path.endswith("_test.py") or path.endswith(".test.js")
]
summary = ""
if stdout_path.exists():
    for line in stdout_path.read_text(encoding="utf-8", errors="replace").splitlines():
        text = line.strip()
        if text:
            summary = text
            break
payload = {
    "task_id": os.environ["ACCRUVIA_TASK_ID"],
    "run_id": os.environ["ACCRUVIA_RUN_ID"],
    "objective": os.environ["ACCRUVIA_TASK_OBJECTIVE"],
    "strategy": os.environ.get("ACCRUVIA_TASK_STRATEGY", "default"),
    "worker_backend": "agent",
    "validation_profile": "generic",
    "worker_outcome": "success" if codex_rc == 0 else "failed",
    "codex_returncode": codex_rc,
    "changed_files": all_changed,
    "test_files": test_files or ["tests/test_cli.py"],
    "compile_check": {
        "passed": compile_rc == 0,
        "targets": [path for path in all_changed if path.endswith(".py")],
        "mode": "py_compile",
        "output_path": str(compile_output_path),
    },
    "test_check": {
        "passed": test_rc == 0,
        "framework": "unittest",
        "output_path": str(test_output_path),
    },
    "summary": summary,
}
report_path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")
PY

if [ "${codex_rc}" -ne 0 ] || [ "${compile_rc}" -ne 0 ] || [ "${test_rc}" -ne 0 ]; then
  exit 1
fi
