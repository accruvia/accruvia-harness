#!/usr/bin/env python3
"""Objective bench: one-screen view of objective + task + review state.

Thin CLI wrapper over ``accruvia_harness.bench``. The library module
holds all the query logic and is unit-tested; this script just formats
output for the terminal.

Usage:
    ./bin/accruvia-objective-bench                       # all open objectives
    ./bin/accruvia-objective-bench --all                 # include resolved
    ./bin/accruvia-objective-bench --objective <id>      # single objective detail
    ./bin/accruvia-objective-bench --db <path>           # alternate db
"""
from __future__ import annotations

import argparse
import sqlite3
import sys
from pathlib import Path

# Add src/ to sys.path so the library import works from a checkout
_repo = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_repo / "src"))

from accruvia_harness.bench import (  # noqa: E402
    ReviewStatus,
    decomposition_coverage,
    latest_review_status,
    mermaid_for_objective,
    ready_to_promote,
    task_counts_for_objective,
)


def _connect(db_path: Path) -> sqlite3.Connection:
    conn = sqlite3.connect(str(db_path))
    conn.row_factory = sqlite3.Row
    return conn


def _format_row(
    objective: sqlite3.Row,
    counts: dict[str, int],
    review: ReviewStatus,
    mermaid: dict | None,
    coverage: dict,
) -> str:
    ready, reason = ready_to_promote(counts, review, coverage)
    ready_marker = "READY" if ready else ".....".ljust(5)

    if review.status == "none":
        review_blurb = "no round yet"
    elif review.status == "running":
        review_blurb = f"running {review.pass_count}p/{review.fail_count}f"
    else:
        review_blurb = f"{'CLEAR' if review.review_clear else 'BLOCKED'} {review.pass_count}p/{review.fail_count}f"

    if coverage["total_nodes"] == 0:
        dec_blurb = "no decomp"
    else:
        dec_blurb = (
            f"{coverage['nodes_completed']}/{coverage['nodes_with_tasks']}/{coverage['total_nodes']}"
        )
        if coverage["gaps"]:
            dec_blurb += f" gaps={len(coverage['gaps'])}"

    title = (objective["title"] or "")[:50]
    return (
        f"[{ready_marker}] p{objective['priority']:<3} "
        f"{objective['id'][-12:]} "
        f"{objective['status']:<9} "
        f"| tasks: {counts['pending']}p {counts['active']}a {counts['completed']}c {counts['failed']}f "
        f"| decomp: {dec_blurb:<18} "
        f"| review: {review_blurb:<24} "
        f"| {title}"
        + ("" if ready else f"  -- {reason}")
    )


def cmd_list(conn: sqlite3.Connection, show_all: bool) -> None:
    q = "SELECT id, title, status, priority FROM objectives WHERE status != 'abandoned'"
    if not show_all:
        q += " AND status NOT IN ('completed')"
    q += " ORDER BY priority DESC, created_at"
    objectives = conn.execute(q).fetchall()

    if not objectives:
        print("No matching objectives.")
        return

    print(f"{len(objectives)} objective(s):")
    print()
    ready_count = 0
    for obj in objectives:
        counts = task_counts_for_objective(conn, obj["id"])
        review = latest_review_status(conn, obj["id"])
        mermaid = mermaid_for_objective(conn, obj["id"])
        coverage = decomposition_coverage(conn, obj["id"])
        print(_format_row(obj, counts, review, mermaid, coverage))
        if ready_to_promote(counts, review, coverage)[0]:
            ready_count += 1

    print()
    print(f"READY: {ready_count} of {len(objectives)}")


def cmd_detail(conn: sqlite3.Connection, objective_id: str) -> None:
    obj = conn.execute("SELECT * FROM objectives WHERE id = ?", (objective_id,)).fetchone()
    if obj is None:
        print(f"Unknown objective: {objective_id}", file=sys.stderr)
        sys.exit(2)
    counts = task_counts_for_objective(conn, objective_id)
    review = latest_review_status(conn, objective_id)
    coverage = decomposition_coverage(conn, objective_id)
    mermaid = mermaid_for_objective(conn, objective_id)
    ready, reason = ready_to_promote(counts, review, coverage)

    print(f"OBJECTIVE {obj['id']}")
    print(f"  title:   {obj['title']}")
    print(f"  status:  {obj['status']}")
    print(f"  priority: {obj['priority']}")
    print(f"  summary: {(obj['summary'] or '')[:200]}")
    print()
    print(
        f"TASKS: {counts['total']} total -- pending={counts['pending']} active={counts['active']}"
        f" completed={counts['completed']} failed={counts['failed']}"
    )
    print()
    print("TASK DETAIL:")
    rows = conn.execute(
        "SELECT id, title, status, strategy, mermaid_node_id FROM tasks WHERE objective_id = ? ORDER BY created_at",
        (objective_id,),
    ).fetchall()
    for r in rows:
        node = r["mermaid_node_id"] or "-"
        print(f"  [{r['status']:<10}] {r['id'][-12:]} node={node:<15} {r['strategy']:<25} {r['title'][:60]}")
    print()
    print("REVIEW:")
    print(f"  status:  {review.status}")
    print(f"  review_id: {review.review_id or '-'}")
    print(f"  packets: {review.packet_count} (pass={review.pass_count}, fail={review.fail_count})")
    print(f"  review_clear: {review.review_clear}")
    if review.completed_at:
        print(f"  completed: {review.completed_at[:19]}")
    print()
    print("MERMAID:")
    if mermaid is None:
        print("  (none)")
    else:
        print(
            f"  id: {mermaid['id']}  type: {mermaid['diagram_type']}  "
            f"v{mermaid['version']}  status: {mermaid['status']}  "
            f"content: {mermaid['clen']} bytes"
        )
    print()
    print("DECOMPOSITION COVERAGE:")
    print(f"  nodes in mermaid:     {coverage['total_nodes']}")
    print(f"  nodes with plans:     {coverage['nodes_with_plans']}")
    print(f"  nodes with tasks:     {coverage['nodes_with_tasks']}")
    print(f"  nodes completed:      {coverage['nodes_completed']}")
    if coverage["gaps"]:
        print(f"  decomposition gaps (nodes with no task): {len(coverage['gaps'])}")
        for g in coverage["gaps"][:10]:
            print(f"    - {g}")
    if coverage["orphan_tasks"]:
        print(f"  orphan tasks (mermaid_node_id not in diagram): {len(coverage['orphan_tasks'])}")
        for t in coverage["orphan_tasks"][:10]:
            print(f"    - {t}")
    print()
    print(f"READY TO PROMOTE: {ready} ({reason})")


def main() -> None:
    parser = argparse.ArgumentParser(description="Objective verification bench.")
    parser.add_argument("--db", default=".accruvia-harness/harness.db")
    parser.add_argument("--all", action="store_true", help="include resolved/completed objectives")
    parser.add_argument("--objective", help="show full detail for a single objective id")
    args = parser.parse_args()
    db_path = Path(args.db)
    if not db_path.exists():
        print(f"Database not found: {db_path}", file=sys.stderr)
        sys.exit(2)
    with _connect(db_path) as conn:
        if args.objective:
            cmd_detail(conn, args.objective)
        else:
            cmd_list(conn, show_all=args.all)


if __name__ == "__main__":
    main()
