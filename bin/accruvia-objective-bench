#!/usr/bin/env python3
"""Objective bench: one-screen view of objective + task + review state.

Reads the harness DB directly (no CLI wiring) and prints one block per
open objective with:
  - status, priority
  - task counts: pending / active / completed / failed
  - latest objective review round: verdict, round status, remediation counts
  - "ready to promote" signal (all tasks done + review clear + nothing unapplied)
  - mermaid diagram presence

Intended for hobble-mode verification: watch objectives pile up tasks until
they're ready for review, without per-task merges landing on main.

Usage:
    ./bin/accruvia-objective-bench                       # all open objectives
    ./bin/accruvia-objective-bench --all                 # include resolved
    ./bin/accruvia-objective-bench --objective <id>      # single objective detail
    ./bin/accruvia-objective-bench --db <path>           # alternate db
"""
from __future__ import annotations

import argparse
import json
import re
import sqlite3
import sys
from pathlib import Path

_NODE_RE = re.compile(r'^\s*([A-Za-z_][A-Za-z0-9_]*)\[')


def _extract_mermaid_nodes(content: str) -> list[str]:
    """Parse node ids from a mermaid flowchart. Returns ids in declaration order.

    A node declaration looks like 'T_abc123["label"]' at the start of a line.
    Edges are ignored. The objective's own 'O' node is filtered out — we only
    care about decomposition children.
    """
    if not content:
        return []
    nodes: list[str] = []
    seen: set[str] = set()
    for line in content.splitlines():
        m = _NODE_RE.match(line)
        if not m:
            continue
        node = m.group(1)
        if node == "O" or node in seen:
            continue
        seen.add(node)
        nodes.append(node)
    return nodes


def _decomposition_coverage(conn: sqlite3.Connection, objective_id: str) -> dict:
    """Compute node-level coverage from mermaid + tasks.

    Returns:
        total_nodes: nodes in the latest mermaid flowchart
        nodes_with_plans: distinct nodes referenced by existing plan rows
        nodes_with_tasks: distinct nodes referenced by existing tasks (any status)
        nodes_completed: distinct nodes whose task is completed
        gaps: node ids in the mermaid but not referenced by any task
        orphan_tasks: tasks whose mermaid_node_id is not in the mermaid
    """
    row = conn.execute(
        """
        SELECT content FROM mermaid_artifacts
         WHERE objective_id = ? AND diagram_type = 'workflow_control'
         ORDER BY version DESC LIMIT 1
        """,
        (objective_id,),
    ).fetchone()
    nodes = _extract_mermaid_nodes(row["content"] if row else "")
    node_set = set(nodes)

    task_rows = conn.execute(
        "SELECT id, mermaid_node_id, status FROM tasks WHERE objective_id = ?",
        (objective_id,),
    ).fetchall()
    plan_rows = conn.execute(
        "SELECT mermaid_node_id FROM plans WHERE objective_id = ? AND mermaid_node_id IS NOT NULL",
        (objective_id,),
    ).fetchall()

    nodes_with_tasks = {t["mermaid_node_id"] for t in task_rows if t["mermaid_node_id"]}
    nodes_completed = {t["mermaid_node_id"] for t in task_rows if t["mermaid_node_id"] and t["status"] == "completed"}
    nodes_with_plans = {p["mermaid_node_id"] for p in plan_rows if p["mermaid_node_id"]}

    gaps = [n for n in nodes if n not in nodes_with_tasks]
    orphan_tasks = [t["id"] for t in task_rows if t["mermaid_node_id"] and t["mermaid_node_id"] not in node_set]

    return {
        "total_nodes": len(nodes),
        "nodes_with_plans": len(nodes_with_plans & node_set) if node_set else len(nodes_with_plans),
        "nodes_with_tasks": len(nodes_with_tasks & node_set),
        "nodes_completed": len(nodes_completed & node_set),
        "gaps": gaps,
        "orphan_tasks": orphan_tasks,
    }


def _connect(db_path: Path) -> sqlite3.Connection:
    conn = sqlite3.connect(str(db_path))
    conn.row_factory = sqlite3.Row
    return conn


def _task_counts_for_objective(conn: sqlite3.Connection, objective_id: str) -> dict[str, int]:
    rows = conn.execute(
        "SELECT status, COUNT(*) AS c FROM tasks WHERE objective_id = ? GROUP BY status",
        (objective_id,),
    ).fetchall()
    counts = {"pending": 0, "active": 0, "completed": 0, "failed": 0}
    for r in rows:
        counts[r["status"]] = r["c"]
    counts["total"] = sum(counts.values())
    return counts


def _latest_review_round(conn: sqlite3.Connection, objective_id: str) -> dict | None:
    """Pull the latest objective_review_round context record if present."""
    rows = conn.execute(
        """
        SELECT metadata_json, created_at
          FROM context_records
         WHERE objective_id = ?
           AND record_type = 'objective_review_round'
         ORDER BY created_at DESC
         LIMIT 1
        """,
        (objective_id,),
    ).fetchall()
    if not rows:
        return None
    try:
        payload = json.loads(rows[0]["metadata_json"] or "{}")
    except json.JSONDecodeError:
        return None
    payload["_created_at"] = rows[0]["created_at"]
    return payload


def _review_packet_count(conn: sqlite3.Connection, objective_id: str) -> int:
    r = conn.execute(
        """
        SELECT COUNT(*) FROM context_records
         WHERE objective_id = ?
           AND record_type = 'objective_review_packet'
        """,
        (objective_id,),
    ).fetchone()
    return int(r[0] or 0)


def _mermaid_for_objective(conn: sqlite3.Connection, objective_id: str) -> dict | None:
    r = conn.execute(
        """
        SELECT id, diagram_type, status, version, required_for_execution,
               LENGTH(content) AS clen
          FROM mermaid_artifacts
         WHERE objective_id = ?
         ORDER BY version DESC
         LIMIT 1
        """,
        (objective_id,),
    ).fetchone()
    return dict(r) if r is not None else None


def _ready_to_promote(counts: dict[str, int], review: dict | None) -> tuple[bool, str]:
    if counts["total"] == 0:
        return False, "no tasks"
    if counts["pending"] or counts["active"]:
        return False, f"{counts['pending']}p/{counts['active']}a still in flight"
    if counts["failed"]:
        return False, f"{counts['failed']} failed"
    if review is None:
        return False, "no review round recorded"
    if review.get("needs_remediation"):
        rc = review.get("remediation_counts") or {}
        return False, f"remediation: {rc.get('pending', 0)}p/{rc.get('active', 0)}a"
    if not review.get("review_clear"):
        return False, f"review status: {review.get('status') or '?'}"
    return True, "clear"


def _format_row(
    objective: sqlite3.Row,
    counts: dict[str, int],
    review: dict | None,
    packet_count: int,
    mermaid: dict | None,
    coverage: dict,
) -> str:
    ready, reason = _ready_to_promote(counts, review)
    ready_marker = "READY" if ready else ".....".ljust(5)

    if review is None:
        review_blurb = "no round yet"
    else:
        rstatus = review.get("status") or "?"
        verdict = review.get("verdict") or "?"
        review_blurb = f"{rstatus}/{verdict}"

    # Decomposition coverage: <completed>/<with_tasks>/<total_nodes>
    if coverage["total_nodes"] == 0:
        dec_blurb = "no decomp"
    else:
        dec_blurb = (
            f"{coverage['nodes_completed']}/{coverage['nodes_with_tasks']}/{coverage['total_nodes']}"
        )
        if coverage["gaps"]:
            dec_blurb += f" gaps={len(coverage['gaps'])}"

    title = (objective["title"] or "")[:50]
    return (
        f"[{ready_marker}] p{objective['priority']:<3} "
        f"{objective['id'][-12:]} "
        f"{objective['status']:<9} "
        f"| tasks: {counts['pending']}p {counts['active']}a {counts['completed']}c {counts['failed']}f "
        f"| decomp: {dec_blurb:<18} "
        f"| review: {review_blurb:<22} "
        f"| pkts:{packet_count:<2} "
        f"| {title}"
        + ("" if ready else f"  -- {reason}")
    )


def cmd_list(conn: sqlite3.Connection, show_all: bool) -> None:
    q = """
        SELECT id, title, status, priority
          FROM objectives
         WHERE status != 'abandoned'
    """
    if not show_all:
        q += " AND status NOT IN ('completed', 'resolved')"
    q += " ORDER BY priority DESC, created_at"
    objectives = conn.execute(q).fetchall()

    if not objectives:
        print("No matching objectives.")
        return

    print(f"{len(objectives)} objective(s):")
    print()
    for obj in objectives:
        counts = _task_counts_for_objective(conn, obj["id"])
        review = _latest_review_round(conn, obj["id"])
        packet_count = _review_packet_count(conn, obj["id"])
        mermaid = _mermaid_for_objective(conn, obj["id"])
        coverage = _decomposition_coverage(conn, obj["id"])
        print(_format_row(obj, counts, review, packet_count, mermaid, coverage))

    ready_count = sum(
        1 for obj in objectives
        if _ready_to_promote(
            _task_counts_for_objective(conn, obj["id"]),
            _latest_review_round(conn, obj["id"]),
        )[0]
    )
    print()
    print(f"READY: {ready_count} of {len(objectives)}")


def cmd_detail(conn: sqlite3.Connection, objective_id: str) -> None:
    obj = conn.execute("SELECT * FROM objectives WHERE id = ?", (objective_id,)).fetchone()
    if obj is None:
        print(f"Unknown objective: {objective_id}", file=sys.stderr)
        sys.exit(2)
    counts = _task_counts_for_objective(conn, objective_id)
    review = _latest_review_round(conn, objective_id)
    packet_count = _review_packet_count(conn, objective_id)
    mermaid = _mermaid_for_objective(conn, objective_id)
    coverage = _decomposition_coverage(conn, objective_id)
    ready, reason = _ready_to_promote(counts, review)

    print(f"OBJECTIVE {obj['id']}")
    print(f"  title:   {obj['title']}")
    print(f"  status:  {obj['status']}")
    print(f"  priority: {obj['priority']}")
    print(f"  summary: {(obj['summary'] or '')[:200]}")
    print()
    print(
        f"TASKS: {counts['total']} total"
        f" -- pending={counts['pending']} active={counts['active']}"
        f" completed={counts['completed']} failed={counts['failed']}"
    )
    print()
    print("TASK DETAIL:")
    rows = conn.execute(
        "SELECT id, title, status, strategy FROM tasks WHERE objective_id = ? ORDER BY created_at",
        (objective_id,),
    ).fetchall()
    for r in rows:
        print(f"  [{r['status']:<10}] {r['id'][-12:]} {r['strategy']:<25} {r['title'][:70]}")
    print()
    print("REVIEW:")
    if review is None:
        print("  (no review round recorded)")
    else:
        print(f"  created: {review.get('_created_at','?')}")
        print(f"  status:  {review.get('status','?')}")
        print(f"  verdict: {review.get('verdict','?')}")
        print(f"  review_clear: {review.get('review_clear', False)}")
        print(f"  needs_remediation: {review.get('needs_remediation', False)}")
        rc = review.get("remediation_counts") or {}
        if rc:
            print(f"  remediation_counts: {rc}")
        print(f"  packet records in DB: {packet_count}")
    print()
    print("MERMAID:")
    if mermaid is None:
        print("  (none)")
    else:
        print(f"  id: {mermaid['id']}  type: {mermaid['diagram_type']}  "
              f"v{mermaid['version']}  status: {mermaid['status']}  "
              f"content: {mermaid['clen']} bytes")
    print()
    print("DECOMPOSITION COVERAGE:")
    print(f"  nodes in mermaid:     {coverage['total_nodes']}")
    print(f"  nodes with plans:     {coverage['nodes_with_plans']}")
    print(f"  nodes with tasks:     {coverage['nodes_with_tasks']}")
    print(f"  nodes completed:      {coverage['nodes_completed']}")
    if coverage["gaps"]:
        print(f"  decomposition gaps (nodes with no task): {len(coverage['gaps'])}")
        for g in coverage["gaps"][:10]:
            print(f"    - {g}")
        if len(coverage["gaps"]) > 10:
            print(f"    ... and {len(coverage['gaps']) - 10} more")
    if coverage["orphan_tasks"]:
        print(f"  orphan tasks (mermaid_node_id not in diagram): {len(coverage['orphan_tasks'])}")
        for t in coverage["orphan_tasks"][:10]:
            print(f"    - {t}")
    print()
    print(f"READY TO PROMOTE: {ready} ({reason})")


def main() -> None:
    parser = argparse.ArgumentParser(description="Objective verification bench.")
    parser.add_argument(
        "--db",
        default=".accruvia-harness/harness.db",
        help="path to harness.db",
    )
    parser.add_argument(
        "--all",
        action="store_true",
        help="include resolved/completed objectives (default: skip them)",
    )
    parser.add_argument(
        "--objective",
        help="show full detail for a single objective id",
    )
    args = parser.parse_args()
    db_path = Path(args.db)
    if not db_path.exists():
        print(f"Database not found: {db_path}", file=sys.stderr)
        sys.exit(2)
    with _connect(db_path) as conn:
        if args.objective:
            cmd_detail(conn, args.objective)
        else:
            cmd_list(conn, show_all=args.all)


if __name__ == "__main__":
    main()
